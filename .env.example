# ──────────────────────────────────────────────
# Real Estate API — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DJANGO_ENV=development
DEBUG=True

# Database — Supabase PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Cloudinary Media Storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — Frontend URLs (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Allowed Hosts (production, comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173

# Email (optional — uses console backend by default)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@landmarket.com

# Paystack (optional — for payment integration)
# PAYSTACK_SECRET_KEY=sk_test_xxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxx
